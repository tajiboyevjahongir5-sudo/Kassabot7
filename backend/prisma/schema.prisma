generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id // Telegram user ID as string
  username  String?
  firstName String?
  subs      Subscription[]
  payments  Payment[]
}

model Channel {
  id        String   @id // Telegram chat ID as string
  title     String
  adminId   String
  plans     Plan[]
  subs      Subscription[]
}

model Plan {
  id          Int      @id @default(autoincrement())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id])
  name        String
  description String?
  price       Int      // Price
  priceType   String   @default("UZS") // Changed to UZS
  duration    Int      // Duration in days
  payments    Payment[]
}

model Subscription {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id])
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED
  expiresAt   DateTime
}

model Settings {
  id               Int     @id @default(1)
  cardNumber       String?
  paymentChannelId String?
  rubRate          Float   @default(155)
}

model Card {
  id             Int      @id @default(autoincrement())
  slot           Int      @unique // 1, 2, 3
  cardNumber     String
  cardHolder     String   @default("")
  bankName       String   @default("")
  transferCount  Int      @default(0)
  maxTransfers   Int      @default(35)
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Payment {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  planId      Int
  plan        Plan     @relation(fields: [planId], references: [id])
  amount      Int      // Exact amount to pay including the random suffix
  status      String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())
  promoCode   String?  // Applied promo code
}

model PromoCode {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  discountType  String   @default("percent") // percent or fixed
  discountValue Int      // e.g. 20 for 20% or 5000 for 5000 UZS off
  maxUses       Int      @default(0) // 0 = unlimited
  usedCount     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}
